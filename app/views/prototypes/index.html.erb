<main class="main">
  <div class="inner">
    <%# ログインしているときは以下を表示する %>
    <% if user_signed_in? %>
       <div class="greeting"> 
          こんにちは、 
         <%= link_to "#{current_user.name}さん", user_path(current_user), class: :greeting__link%>
       </div> 
    <% end %>
    <div class="card__wrapper">
      <%# allで持ってきた配列@prototypesを繰り返し表示する collection: は以下の処理を自動で行う%>
      <%# @prototypes.each do |prototype| %>
      <%# render partial: "prototype", locals: { prototype: prototype } %>
      <%# end %>
      <%= render partial: "prototype", collection: @prototypes %>
    </div>
  </div>
</main>
